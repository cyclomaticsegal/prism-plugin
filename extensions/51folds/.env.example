# 51Folds extension credentials.
#
# Copy this file to `.env` (in the same folder) and fill in your token.
# The .env file is gitignored — never commit it.
#
# Get your token from https://app.51folds.ai/account/tokens

FOLDS_API_TOKEN=your-token-here

# Optional overrides (leave commented unless 51Folds tells you to use a non-default endpoint)
# FOLDS_API_URL=https://api.51folds.ai
# FOLDS_PLATFORM_URL=https://app.51folds.ai
